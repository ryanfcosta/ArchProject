<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #1e272e;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simumic.PrimaryController">
   <children>
      <Label text="DATAPATH DO MIC-1" textFill="#0fb9b1">
         <font> <Font name="System Bold" size="24.0" /> </font>
      </Label>

      <AnchorPane prefWidth="600.0" prefHeight="400.0" style="-fx-background-color: #2f3640; -fx-background-radius: 10; -fx-border-color: #718093; -fx-border-radius: 10; -fx-border-width: 2;">
         <children>
            
            <Line startX="300.0" startY="80.0" endX="300.0" endY="110.0" stroke="#fbc531" strokeWidth="3.0" />
            <Line startX="160.0" startY="110.0" endX="440.0" endY="110.0" stroke="#fbc531" strokeWidth="3.0" />
            <Line startX="160.0" startY="110.0" endX="160.0" endY="140.0" stroke="#fbc531" strokeWidth="3.0" />
            <Line startX="440.0" startY="110.0" endX="440.0" endY="140.0" stroke="#fbc531" strokeWidth="3.0" />
            <Line startX="440.0" startY="200.0" endX="440.0" endY="260.0" stroke="#e84118" strokeWidth="3.0" />
            
            <!-- PC --> 
            <StackPane layoutX="250.0" layoutY="20.0">
               <Rectangle width="100.0" height="60.0" fill="#2c3e50" stroke="#4cd137" strokeWidth="3.0" arcWidth="10.0" arcHeight="10.0" />
               <VBox alignment="CENTER">
                  <Label text="PC" textFill="WHITE" style="-fx-font-weight: bold;" />
                  <Label fx:id="labelPC" text="0000" textFill="#4cd137"> <font><Font name="Monospaced Bold" size="18.0" /></font> </Label>
               </VBox>
            </StackPane>

            <StackPane layoutX="110.0" layoutY="140.0">
               <Rectangle width="100.0" height="60.0" fill="#2c3e50" stroke="#00a8ff" strokeWidth="3.0" arcWidth="10.0" arcHeight="10.0" />
               <VBox alignment="CENTER">
                  <Label text="MAR" textFill="WHITE" style="-fx-font-weight: bold;" />
                  <Label fx:id="labelMAR" text="0000" textFill="#00a8ff"> <font><Font name="Monospaced Bold" size="18.0" /></font> </Label>
               </VBox>
            </StackPane>

            <StackPane layoutX="390.0" layoutY="140.0">
               <Rectangle width="100.0" height="60.0" fill="#2c3e50" stroke="#00a8ff" strokeWidth="3.0" arcWidth="10.0" arcHeight="10.0" />
               <VBox alignment="CENTER">
                  <Label text="MBR" textFill="WHITE" style="-fx-font-weight: bold;" />
                  <Label fx:id="labelMBR" text="0000" textFill="#00a8ff"> <font><Font name="Monospaced Bold" size="18.0" /></font> </Label>
               </VBox>
            </StackPane>

            <StackPane layoutX="110.0" layoutY="260.0">
               <Rectangle width="100.0" height="60.0" fill="#2c3e50" stroke="#9c88ff" strokeWidth="3.0" arcWidth="10.0" arcHeight="10.0" />
               <VBox alignment="CENTER">
                  <Label text="AC" textFill="WHITE" style="-fx-font-weight: bold;" />
                  <Label fx:id="labelAC" text="0000" textFill="#9c88ff"> <font><Font name="Monospaced Bold" size="18.0" /></font> </Label>
               </VBox>
            </StackPane>

            <StackPane layoutX="390.0" layoutY="260.0">
               <Rectangle width="100.0" height="60.0" fill="#2c3e50" stroke="#e84118" strokeWidth="3.0" arcWidth="10.0" arcHeight="10.0" />
               <VBox alignment="CENTER">
                  <Label text="IR" textFill="WHITE" style="-fx-font-weight: bold;" />
                  <Label fx:id="labelIR" text="0000" textFill="#e84118"> <font><Font name="Monospaced Bold" size="18.0" /></font> </Label>
               </VBox>
            </StackPane>

         </children>
      </AnchorPane>

      <HBox alignment="CENTER" spacing="10.0">
         <Label text="Comando Binário:" textFill="#ecf0f1" />
         <TextField fx:id="inputInstrucao" promptText="0000000000001010" prefWidth="180.0" style="-fx-font-family: 'Monospaced';" />
         <Button text="Gravar na RAM" onAction="#ramWrite" style="-fx-background-color: #44bd32; -fx-text-fill: white;" />
      </HBox>

      <Button fx:id="primaryButton" text="PRÓXIMO PASSO (FETCH)" onAction="#execCiclo" style="-fx-background-color: #c23616; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10 20;"/>
   </children>
   
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>