<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" style="-fx-background-color: #000000;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.simumic.TertiaryController">

    <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>

    <Label text="CACHE — MAPEAMENTO DIRETO" textFill="#077d29"
           style="-fx-font-weight: bold; -fx-font-size: 16; -fx-font-family: Monospaced;"/>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">

        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label fx:id="labelTituloL1" text="L1" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-size: 14; -fx-font-family: Monospaced;"/>
                <Label fx:id="labelStatsL1" text="HITS=0  MISSES=0  (0.0%)"
                       textFill="#bdc3c7" style="-fx-font-size: 11;"/>
            </HBox>

            <HBox spacing="12.0" style="-fx-border-color: #f1c40f; -fx-border-width: 0 0 1 0; -fx-padding: 4 10 4 10;">
                <Label text="Linha" prefWidth="55.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="V" prefWidth="35.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="TAG" prefWidth="60.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="Bloco (end.)" prefWidth="110.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="Conteúdo" prefWidth="200.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
            </HBox>

            <ListView fx:id="listaL1" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #000000; -fx-border-color: #333;
                             -fx-font-family: Monospaced; -fx-font-size: 12;"/>
        </VBox>

        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label fx:id="labelTituloL2" text="L2" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-size: 14; -fx-font-family: Monospaced;"/>
                <Label fx:id="labelStatsL2" text="HITS=0  MISSES=0  (0.0%)"
                       textFill="#bdc3c7" style="-fx-font-size: 11;"/>
            </HBox>

            <HBox spacing="12.0" style="-fx-border-color: #f1c40f; -fx-border-width: 0 0 1 0; -fx-padding: 4 10 4 10;">
                <Label text="Linha" prefWidth="55.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="V" prefWidth="35.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="TAG" prefWidth="60.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="Bloco (end.)" prefWidth="110.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
                <Label text="Conteúdo" prefWidth="200.0" alignment="CENTER" textFill="#f1c40f"
                       style="-fx-font-weight: bold; -fx-font-family: Monospaced; -fx-font-size: 12;"/>
            </HBox>

            <ListView fx:id="listaL2" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #000000; -fx-border-color: #333;
                             -fx-font-family: Monospaced; -fx-font-size: 12;"/>
        </VBox>

    </HBox>
</VBox>
